{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2021"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "outDir": "../dist",
    "noEmit": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["_generated"]
}
