# Convex Backend
# Set these in Convex dashboard > Settings > Environment Variables
# (This file is for reference only -- Convex env vars are NOT read from .env files)

# ---- Auth (Required) ----
AUTH_GOOGLE_ID=                         # Google OAuth client ID
AUTH_GOOGLE_SECRET=                     # Google OAuth client secret
JWT_PRIVATE_KEY=                        # RSA 2048 private key (PEM format)
JWKS=                                   # RSA public key (JWK JSON format)
SITE_URL=http://localhost:3000          # Your web app URL

# ---- Magic Link Email Auth ----
AUTH_RESEND_KEY=                        # Resend API key (from resend.com/api-keys)
AUTH_RESEND_FROM=onboarding@resend.dev  # Sender email (verify domain in Resend)

# ---- Deployment ----
CONVEX_DEPLOY_KEY=                      # For CI/CD only

# ---- Cloudflare R2 Storage ----
R2_TOKEN=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=

# ---- Dodo Payments ----
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode     # test_mode or live_mode
DODO_PAYMENTS_WEBHOOK_SECRET=

# ---- Resend Email ----
RESEND_API_KEY=

# ---- OpenAI (AI Agent + RAG) ----
OPENAI_API_KEY=
AGENT_MODEL=gpt-4o-mini                 # Chat model for agent + RAG (optional, default: gpt-4o-mini)
RAG_EMBEDDING_MODEL=text-embedding-3-small  # Embedding model for RAG (optional, default: text-embedding-3-small)

# ---- Streaming ----
WEB_ORIGIN=http://localhost:3000         # CORS origin for /chat-stream endpoint
