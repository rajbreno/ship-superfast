{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build",
        "@repo/convex#codegen"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types",
        "@repo/convex#codegen"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@repo/convex#dev": {
      "cache": false,
      "persistent": true
    },
    "@repo/convex#codegen": {
      "cache": false,
      "outputs": [
        "convex/_generated/**"
      ],
      "env": [
        "CONVEX_DEPLOY_KEY"
      ]
    }
  }
}
