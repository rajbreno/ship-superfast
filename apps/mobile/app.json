{
  "expo": {
    "name": "Ship Superfast",
    "slug": "ship-superfast",
    "version": "1.0.0",
    "scheme": "shipsuperfast",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./src/assets/appicon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rajbreno.shipsuperfast",
      "icon": "./src/assets/appicon.png"
    },
    "android": {
      "package": "com.rajbreno.shipsuperfast",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/appicon.png",
        "backgroundColor": "#F55A00"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F55A00",
          "image": "./src/assets/brand-logo.png",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#F55A00",
            "image": "./src/assets/brand-logo.png"
          }
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "37103778-bef9-4f12-b132-b84a65630ace"
      }
    },
    "owner": "rajbreno",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/37103778-bef9-4f12-b132-b84a65630ace"
    }
  }
}
